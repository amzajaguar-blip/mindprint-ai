# ── Supabase ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[project-ref].supabase.co:5432/postgres
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ── OAuth Manus ──────────────────────────────────────────
OAUTH_SERVER_URL=https://auth.manus.im
OWNER_OPEN_ID=your-owner-open-id

# ── LLM & Image Generation (Manus Forge) ─────────────────
BUILT_IN_FORGE_API_URL=https://forge.manus.im/v1
BUILT_IN_FORGE_API_KEY=your-forge-api-key

# ── AWS S3 ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=eu-west-1
AWS_BUCKET_NAME=mindprint-images

# ── Lemon Squeezy ────────────────────────────────────────
LEMONSQUEEZY_API_KEY=your-lemon-api-key
LEMONSQUEEZY_STORE_ID=123456
LEMONSQUEEZY_VARIANT_ID=789012
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret

# ── App ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
VITE_APP_ID=mindprint-app
